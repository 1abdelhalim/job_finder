# Copy to .env and fill in. Used by main.py / pipeline / app (python-dotenv).

# --- Optional job board APIs (enable adzuna + jsearch in profile.yaml search.boards) ---
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# RAPIDAPI_KEY=

# --- Digest email (Gmail SMTP app password, not your normal password) ---
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# NOTIFY_EMAIL=

# --- CI / one-off: force digest email on pipeline run ---
# FORCE_DIGEST=1
