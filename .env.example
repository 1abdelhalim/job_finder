# Copy to .env and fill in. Used by main.py / pipeline / app (python-dotenv).

# --- Optional job board APIs (add adzuna / jsearch to profile search.boards if you set these) ---
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=
# RAPIDAPI_KEY=

# --- Digest email (Gmail SMTP app password, not your normal password) ---
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# NOTIFY_EMAIL=

# --- CI / one-off: force digest email on pipeline run ---
# FORCE_DIGEST=1

# --- Optional: override profile pipeline.digest_min_score (digest lists jobs ≥ this, 0–1) ---
# DIGEST_MIN_SCORE=0.75
